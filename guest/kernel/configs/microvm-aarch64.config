#
# Minimal kernel config for Cloud Hypervisor microVMs — ARM64 (aarch64)
#
# Based on the x86 microvm.config, adapted for ARM64:
# - No PVH boot (ARM64 uses direct kernel boot)
# - PL011 serial console instead of 8250/virtio-console
# - ARM GIC interrupt controller
# - PSCI for CPU management
#
# Use with `make olddefconfig` to fill defaults.
#

# --- Architecture ---
CONFIG_ARM64=y

# --- ARM64 boot (direct kernel boot — no PVH/Xen on ARM) ---
# Can't enable these in container builds, need to figure out why:
# - CONFIG_ARM_PSCI
# - CONFIG_CMDLINE_BOOL

CONFIG_ARM_PSCI_CHECKER=n

# --- Interrupt controller (ARM GIC) ---
CONFIG_ARM_GIC=y
CONFIG_ARM_GIC_V3=y

# --- Serial console (ARM PL011 UART) ---
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

